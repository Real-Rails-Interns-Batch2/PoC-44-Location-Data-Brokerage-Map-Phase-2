# ─────────────────────────────────────────────────────────────
#  Real Rails PoC 44 — Environment Variables
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Ports (optional — defaults shown) ────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Frontend → Backend URL ────────────────────────────────────
# Inside Docker Compose, the frontend reaches the backend via
# the service name "backend". For external/browser access,
# change this to your public domain or IP.
NEXT_PUBLIC_API_URL=http://backend:8000

# ── Mapbox (add your token when integrating map tiles) ───────
# Get yours at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Backend runtime ───────────────────────────────────────────
ENVIRONMENT=production

# ── Future: data API keys (add as needed) ────────────────────
# DATA_API_KEY=
# DATA_API_SECRET=
